# 应用设置
# APP_ENV: 应用运行环境，可选值 development/production/testing
# APP_LOG_LEVEL: 日志级别，可选 DEBUG/INFO/WARNING/ERROR/CRITICAL
APP_ENV=development
APP_LOG_LEVEL=INFO

# Ollama 设置
# OLLAMA_BASE_URL: Ollama 服务地址
# OLLAMA_MODEL: Ollama 模型名称
# OLLAMA_TIMEOUT: 请求超时时间（秒）
# OLLAMA_KEEP_ALIVE: 连接保持时间
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT=1200
OLLAMA_KEEP_ALIVE=5m

# PostgreSQL 设置
# POSTGRES_HOST: 数据库主机
# POSTGRES_PORT: 数据库端口
# POSTGRES_DB: 数据库名
# POSTGRES_USER: 数据库用户名
# POSTGRES_PASSWORD: 数据库密码
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_backend
POSTGRES_USER=wangzilong
POSTGRES_PASSWORD=ai_backend_password

# Embedding 设置
# EMBEDDING_MODEL: Embedding 模型名称
# EMBEDDING_BATCH_SIZE: Embedding 批处理大小
# EMBEDDING_DIMENSION: Embedding 向量维度
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_BATCH_SIZE=1500
EMBEDDING_DIMENSION=768

# Reranker / RAG 设置
# RERANKER_ENABLED: 是否启用 reranker
# RERANKER_MODEL: reranker 模型名称
# RERANKER_USE_FP16: 是否使用 FP16 精度
# RAG_CANDIDATE_K: 向量检索候选数
# RAG_RERANK_TOP_N: reranker 返回 top n
# RAG_MAX_RERANK_CONTENT_CHARS: reranker 最大输入字符数
# RAG_DEFAULT_RETRIEVAL_MODE: 默认检索模式
# RAG_VECTOR_TOP_K: 向量检索 top k
# RAG_KEYWORD_TOP_K: 关键词检索 top k
# RAG_FUSION_TOP_K: 融合检索 top k
# RAG_RRF_K: RRF 合并系数 k
# RAG_MMR_ENABLED: 是否启用 MMR
# RAG_MMR_LAMBDA: MMR 权重系数
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_USE_FP16=false
RAG_CANDIDATE_K=30
RAG_RERANK_TOP_N=5
RAG_MAX_RERANK_CONTENT_CHARS=1200

RAG_DEFAULT_RETRIEVAL_MODE=vector_rerank
RAG_VECTOR_TOP_K=30
RAG_KEYWORD_TOP_K=30
RAG_FUSION_TOP_K=20
RAG_RRF_K=60
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.7

# Agent 设置
# AGENT_ALLOWED_TOOLS: 允许的工具列表，逗号分隔
# AGENT_TOOL_TIMEOUT_SECONDS: 工具调用超时时间（秒）
# AGENT_MAX_TOOL_RESULT_CHARS: 工具结果允许的最大字符数
AGENT_ALLOWED_TOOLS=list_docs,search_docs,read_doc
AGENT_TOOL_TIMEOUT_SECONDS=300
AGENT_MAX_TOOL_RESULT_CHARS=8000
