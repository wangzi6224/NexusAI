# =====================================================
# NexusAI 基础配置
# =====================================================

# APP_ENV
# 应用运行环境：
# development | testing | production
APP_ENV=development

# APP_LOG_LEVEL
# 日志级别：
# DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_LEVEL=INFO


# =====================================================
# 本地 Ollama 配置
# =====================================================

# OLLAMA_BASE_URL
# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_MODEL
# 默认本地模型
OLLAMA_MODEL=gemma4:e2b

# OLLAMA_TIMEOUT
# 请求超时时间（秒）
OLLAMA_TIMEOUT=1200

# OLLAMA_KEEP_ALIVE
# 模型驻留时间
OLLAMA_KEEP_ALIVE=5m


# =====================================================
# LLM Provider 配置
# =====================================================

# LLM_PROVIDER
# 模型提供商：
# ollama | cloud
LLM_PROVIDER=cloud

# CLOUD_PROVIDER
# 云模型提供商：
# deepseek | qwen | glm
CLOUD_PROVIDER=deepseek

# 自动路由模型
LLM_ROUTER_MODEL=deepseek-v4-flash


# =====================================================
# DeepSeek 配置
# =====================================================

# OpenAI Compatible API
DEEPSEEK_BASE_URL=https://api.deepseek.com

# API Key
# DEEPSEEK_API_KEY=xxx

# 模型
# deepseek-v4-flash
# deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-flash

# 超时时间（秒）
DEEPSEEK_TIMEOUT=120


# =====================================================
# Qwen 配置
# =====================================================

# OpenAI Compatible API
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
QWEN_MODEL=qwen3.7-max

# 超时时间（秒）
QWEN_TIMEOUT=120

# API Key
# QWEN_API_KEY=xxx


# =====================================================
# GLM 配置
# =====================================================

# OpenAI Compatible API
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 模型名称
GLM_MODEL=glm-5.1

# 超时时间（秒）
GLM_TIMEOUT=120

# API Key
# GLM_API_KEY=xxx


# =====================================================
# PostgreSQL 数据库配置
# =====================================================

# 数据库主机
POSTGRES_HOST=localhost

# 数据库端口
POSTGRES_PORT=5432

# 数据库名称
POSTGRES_DB=ai_backend

# 数据库用户名
POSTGRES_USER=wangzilong

# 数据库密码
POSTGRES_PASSWORD=ai_backend_password


# =====================================================
# Embedding 配置
# =====================================================

# EMBEDDING_MODEL
# 支持：
#
# 在线模型：
# intfloat/multilingual-e5-base
#
# 本地模型：
# ./models/embedding/multilingual-e5-base
#
EMBEDDING_MODEL=./models/embedding/multilingual-e5-base

# 批处理大小
EMBEDDING_BATCH_SIZE=1500

# 向量维度
EMBEDDING_DIMENSION=768


# =====================================================
# Reranker 配置
# =====================================================

# 是否启用重排序
RERANKER_ENABLED=true

# 支持：
#
# 在线模型：
# BAAI/bge-reranker-base
#
# 本地模型：
# ./models/reranker/bge-reranker-base
#
RERANKER_MODEL=./models/reranker/bge-reranker-base

# 是否启用 FP16
RERANKER_USE_FP16=false


# =====================================================
# RAG 检索配置
# =====================================================

# 第一阶段向量召回数量
RAG_CANDIDATE_K=30

# Reranker 最终保留数量
RAG_RERANK_TOP_N=5

# Reranker 单条最大文本长度
RAG_MAX_RERANK_CONTENT_CHARS=1200

# 默认检索模式：
# vector
# vector_rerank
# hybrid
RAG_DEFAULT_RETRIEVAL_MODE=vector_rerank

# 向量召回 TopK
RAG_VECTOR_TOP_K=30

# 关键词召回 TopK
RAG_KEYWORD_TOP_K=30

# RRF 融合后保留数量
RAG_FUSION_TOP_K=20

# Reciprocal Rank Fusion 系数
RAG_RRF_K=60

# 是否启用 MMR 去重
RAG_MMR_ENABLED=true

# MMR 多样性系数
# 越大越关注相关性
# 越小越关注结果多样性
RAG_MMR_LAMBDA=0.7


# =====================================================
# Agent 配置
# =====================================================

# Assistant 统一入口默认最大步骤数
ASSISTANT_MAX_STEPS=6

# 独立 Agent API 默认最大步骤数
AGENT_MAX_STEPS=15

# 允许 Agent 调用的工具
AGENT_ALLOWED_TOOLS=list_docs,search_docs,read_doc

# 工具超时时间（秒）
AGENT_TOOL_TIMEOUT_SECONDS=300

# 工具结果最大长度
AGENT_MAX_TOOL_RESULT_CHARS=40000


# =====================================================
# Planner 配置
# =====================================================

# Planner 类型
# rule | llm
AGENT_PLANNER_TYPE=llm

# Planner 超时时间（秒）
AGENT_PLANNER_TIMEOUT_SECONDS=8

# Planner 温度
AGENT_PLANNER_TEMPERATURE=0

# =====================================================
# MCP 配置
# =====================================================

# 是否启用 MCP 功能
MCP_ENABLED=false

# 允许 MCP 调用的工具列表，逗号分隔
MCP_ALLOWED_TOOLS=mcp__nexusai__list_docs,mcp__nexusai__search_docs,mcp__nexusai__read_doc

# MCP 工具结果最大长度，避免过长导致上下文超限或性能问题
MCP_MAX_RESULT_CHARS=40000

# MCP 工具超时时间（秒）
MCP_DEFAULT_TIMEOUT_SECONDS=15

# MCP 认证 Token
NEXUSAI_MCP_TOKEN=这他妈是token

# =====================================================
# Context 配置
# =====================================================

MAX_CONTEXT_TOKENS_DEFAULT=1048576
LLM_MAX_CONTEXT_TOKENS=glm-5.1:198000,deepseek-v4-flash:1048576,deepseek-v4-pro:1048576,qwen3.7-max:1048576


# =====================================================
# LLMOps Observability 配置
# =====================================================

OBSERVABILITY_ENABLED=true
TRACE_INPUT_MAX_CHARS=2000
TRACE_OUTPUT_MAX_CHARS=3000
TRACE_STORE_FULL_PROMPT=false

# Optional Langfuse
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Optional OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
